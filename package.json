{
  "name": "kabaddiadda",
  "version": "0.1.0",
  "private": true,
  "description": "Multitenant Kabaddi platform — web + mobile",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@kabaddiadda/web",
    "dev:mobile": "turbo run dev --filter=@kabaddiadda/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @kabaddiadda/db generate",
    "db:push": "pnpm --filter @kabaddiadda/db push",
    "db:studio": "pnpm --filter @kabaddiadda/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
