# =====================================================
# Kabaddiadda — environment variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local
# =====================================================

# --- Supabase (get these from your Supabase project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
# Server-only. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# --- Postgres direct connection (Supabase → Settings → Database → Connection string) ---
# Used by Drizzle migrations. Use the "Session" pooler URL for migrations.
DATABASE_URL=postgresql://postgres.YOUR-REF:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- App config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Root domain for tenant subdomain routing (e.g. kabaddiadda.com).
# In dev, leave as localhost — middleware will use path-based routing locally.
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
