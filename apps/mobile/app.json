{
  "expo": {
    "name": "Kabaddiadda",
    "slug": "kabaddiadda",
    "scheme": "kabaddiadda",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kabaddiadda.app"
    },
    "android": {
      "package": "com.kabaddiadda.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
