# See ../../.env.example for full reference. Copy to apps/web/.env.local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# --- Billing (Razorpay) ----------------------------------------------------
# All four are required for the subscribe / cancel / webhook flows to work.
# Test-mode keys (rzp_test_…) are fine for development.
BILLING_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Razorpay plan ID for the Pro tier (₹4,999/month). Create the plan in
# the Razorpay dashboard: Subscriptions → Plans → Create plan.
RAZORPAY_PLAN_PRO_ID=
