# See ../../.env.example for full reference. Copy to apps/web/.env.local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# --- Transactional email (SMTP) -------------------------------------------
# Sends welcome + password-reset emails via our own mailbox (not Supabase).
# Port 465 = implicit SSL/TLS; 587 = STARTTLS. SMTP_FROM defaults to SMTP_USER.
SMTP_HOST=mail.kabaddiadda.in
SMTP_PORT=465
SMTP_USER=info@kabaddiadda.in
SMTP_PASS=
SMTP_FROM=Kabaddiadda <info@kabaddiadda.in>

# --- Billing (Razorpay) ----------------------------------------------------
# All four are required for the subscribe / cancel / webhook flows to work.
# Test-mode keys (rzp_test_…) are fine for development.
BILLING_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Razorpay plan ID for the Pro tier (₹4,999/month). Create the plan in
# the Razorpay dashboard: Subscriptions → Plans → Create plan.
RAZORPAY_PLAN_PRO_ID=

# --- PostHog analytics --------------------------------------------------
# Powers the "Live visitors" link in /admin/traffic. Sign up at posthog.com,
# create a project, and paste the public project API key (starts with phc_).
# When unset, the PostHog provider gracefully no-ops — no tracking happens
# and nothing breaks. Pick the host that matches the region you signed up
# in (US default; EU users override).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
